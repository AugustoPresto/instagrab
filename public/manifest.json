{
  "manifest_version": 3,
  "name": "InstaGrab",
  "version": "1.0.0",
  "description": "Download Instagram photos and videos in full resolution — single posts, carousels, and reels.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "InstaGrab"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "downloads",
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://*.cdninstagram.com/*",
    "https://*.fbcdn.net/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["*.js", "*.css", "*.png"],
      "matches": ["https://www.instagram.com/*"]
    }
  ]
}
